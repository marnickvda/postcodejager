# Strava API app credentials — create one at https://www.strava.com/settings/api
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_REDIRECT_URI=http://localhost:8000/auth/callback

# BRouter routing engine (public server by default; self-host for heavy use)
BROUTER_BASE_URL=https://brouter.de/brouter
# Profile that prefers paved ways and avoids unpaved/gravel for a road bike
BROUTER_PROFILE=trekking
