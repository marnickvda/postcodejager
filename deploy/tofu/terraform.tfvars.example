# Copy to terraform.tfvars and fill in. terraform.tfvars is gitignored.
hcloud_token     = "your-hetzner-cloud-token"
hetznerdns_token = "your-hetzner-dns-token"
dns_zone         = "postcodejager.nl"
subdomain        = "@" # "@" = apex (postcodejager.nl); or "www"
ssh_public_key   = "ssh-ed25519 AAAA... your-key"
